{
  "manifest_version": 3,
  "name": "Immersive Translate Clone",
  "version": "1.0.0",
  "description": "Bilingual webpage translation in your browser. Inspired by Immersive Translate.",
  "permissions": ["storage", "activeTab", "contextMenus", "scripting"],
  "host_permissions": [
    "https://translate.googleapis.com/*",
    "https://api.cognitive.microsofttranslator.com/*",
    "https://edge.microsoft.com/translate/auth/*",
    "https://*.openai.com/*",
    "https://api.openai.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Immersive Translate Clone"
  },
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "src/assets/icon16.png",
    "48": "src/assets/icon48.png",
    "128": "src/assets/icon128.png"
  },
  "commands": {
    "toggle-translation": {
      "suggested_key": {
        "default": "Alt+T"
      },
      "description": "Toggle webpage translation on/off"
    }
  }
}
